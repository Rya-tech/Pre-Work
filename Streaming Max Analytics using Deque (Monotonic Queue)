from collections import deque

def streaming_max(nums, k):
    dq = deque()
    result = []

    for i in range(len(nums)):

        while dq and dq[0] <= i - k:
            dq.popleft()

        while dq and nums[dq[-1]] < nums[i]:
            dq.pop()

        dq.append(i)

        if i >= k - 1:
            result.append(nums[dq[0]])

    return result


data = [10, 5, 2, 7, 8, 7]
k = 3

print(streaming_max(data, k))
